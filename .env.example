# ──────────────────────────────────────────
# RAG Knowledge Assistant — Environment Config
# Copy this file to .env and fill in values
# ──────────────────────────────────────────

# App
APP_NAME="RAG Knowledge Assistant"
APP_VERSION="1.0.0"
DEBUG=false

# Embedding model (HuggingFace sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Retrieval
TOP_K=5

# LLM provider: "extractive" (no API key needed), "openai", "anthropic"
LLM_PROVIDER=extractive

# Required only when LLM_PROVIDER=openai
OPENAI_API_KEY=

# Required only when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
