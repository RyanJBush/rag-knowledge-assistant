# Backend
APP_NAME="RAG Knowledge Assistant"
APP_ENV="development"
API_PREFIX="/api"
LOG_LEVEL="INFO"
CORS_ALLOWED_ORIGINS="http://localhost:5173"
UPLOAD_DIR="backend/data/uploads"
VECTOR_STORE_DIR="backend/data/vector_store"
MAX_UPLOAD_MB=10

# RAG
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=4
EMBEDDING_PROVIDER="sentence-transformers"
EMBEDDING_MODEL="all-MiniLM-L6-v2"
LLM_PROVIDER="mock"
LLM_MODEL="local"
OPENAI_API_KEY=""
